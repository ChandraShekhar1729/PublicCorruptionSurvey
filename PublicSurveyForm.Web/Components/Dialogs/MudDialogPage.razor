@using Microsoft.AspNetCore.Components
@using PublicSurveyForm.Domain.Models
@inject NavigationManager NavigationManager
<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6" Style="color:#D2691E; font-weight:600;">
            @Constants.SurveyDialogTitle
        </MudText>
    </TitleContent>

    <DialogContent>
        <MudText Style="color:#5A5A5A; line-height:1.6;">
            @Constants.SurveyDialogContent
        </MudText>
    </DialogContent>

    <DialogActions>
        <div style="display:flex; justify-content:center; width:100%; padding:12px 0;">
            <button @onClick="Submit"
                       Variant="Variant.Filled"
                       Style="background-color:#E07A28; color:white; padding:8px 32px; border-radius:8px; font-weight:600; letter-spacing:0.5px;">
                PROCEED
            </button>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;


    private void Submit() {
       
        MudDialog.Close();
        NavigationManager!.NavigateTo(Constants.SurveyPageUrl);
    }
}
